# Normalize line endings: store every text file with LF in the repo and check
# it out as LF on every platform. This stops Windows' core.autocrlf from
# rewriting files to CRLF and producing phantom "modified" diffs when WSL/Linux
# tooling later writes them back as LF.
* text=auto eol=lf

# Windows-only scripts must keep CRLF to run.
*.bat text eol=crlf
*.cmd text eol=crlf
